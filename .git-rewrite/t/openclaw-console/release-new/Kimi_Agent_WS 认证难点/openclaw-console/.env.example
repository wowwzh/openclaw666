# OpenClaw Console 环境变量配置

# Gateway WebSocket URL
# 本地开发: ws://127.0.0.1:18789
# 生产环境: wss://your-domain.com/ws
REACT_APP_GATEWAY_URL=ws://127.0.0.1:18789

# Gateway 认证 Token
# 从环境变量获取: echo $OPENCLAW_GATEWAY_TOKEN
# 或从配置文件获取: openclaw config get gateway.auth.token
REACT_APP_GATEWAY_TOKEN=your-gateway-token-here

# 可选: 客户端 ID
REACT_APP_CLIENT_ID=openclaw-console

# 可选: 协议版本 (默认: 3)
REACT_APP_PROTOCOL_VERSION=3
