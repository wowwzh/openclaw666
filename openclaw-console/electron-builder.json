{
  "appId": "com.openclaw.console",
  "productName": "OpenClaw Console",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "artifactName": "${productName}-${version}-${arch}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "OpenClaw Console"
  },
  "mac": {
    "target": ["dmg", "zip"],
    "category": "public.app-category.productivity",
    "artifactName": "${productName}-${version}-${arch}.${ext}"
  },
  "linux": {
    "target": ["AppImage", "deb", "rpm"],
    "category": "Utility",
    "artifactName": "${productName}-${version}-${arch}.${ext}"
  },
  "publish": null
}
